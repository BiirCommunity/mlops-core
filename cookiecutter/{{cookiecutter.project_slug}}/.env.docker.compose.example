# Локальный env для docker compose (скопируйте в .env.docker.compose)

# --- App ---
DEVICE=cuda
CHECKPOINT_PATH=/models/model.pt
TOKENIZER_NAME=meta-llama/Meta-Llama-3-8B
MAX_CONTEXT_TOKENS=4096
PORT=8080
CKPT_HOST_DIR=./models

# --- HuggingFace (gated models / tokenizer) ---
HF_TOKEN=

# --- Auth (legacy fallback) ---
ACCESS_TOKEN=changeme-set-strong-token
INFERENCE_API_KEY=changeme-set-inference-api-key

# --- Grafana ---
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# --- TTT / Redis ---
REDIS_URL=redis://redis-llm:6379
TTT_STEPS=5
TTT_LR=1e-3
TTT_SAVE_EACH_STEP=0
SESSION_TTL_SEC=3600
SESSION_LOCK_TTL_SEC=30
SESSION_LOCK_BLOCKING_TIMEOUT_SEC=10

# --- Toxicity / Drift ---
TOXICITY_MODEL_NAME=unitary/multilingual-toxic-xlm-roberta
TOXICITY_DEVICE=cpu
DRIFT_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
DRIFT_EMBEDDING_DEVICE=cpu
DRIFT_BASELINE_SIZE=200
DRIFT_WINDOW_SIZE=100
DRIFT_REPORT_DIR=/app/reports/drift
DRIFT_REPORT_INTERVAL_SEC=300
DRIFT_REPORT_MIN_WINDOW_SAMPLES=10

# --- MinIO ---
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=0
MINIO_BUCKET_MODELS={{ cookiecutter.minio_bucket_models }}
MINIO_BUCKET_DATASETS={{ cookiecutter.minio_bucket_datasets }}
MINIO_CONSOLE_URL=http://localhost:9001
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# --- DVC ---
DVC_MINIO_ENDPOINT=http://127.0.0.1:9000
DVC_BUCKET={{ cookiecutter.minio_bucket_models }}
DVC_PREFIX=dvc

# --- MLflow ---
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=llm-lora-posttrain
MLFLOW_MODEL_NAME=llm-lora
MLFLOW_UI_URL=http://{{ cookiecutter.mlops_registry }}

# --- LoRA post-train / Admin UI ---
TRAINING_DATA_DIR=/app/data/training
TRAINING_JOBS_DIR=/app/reports/training
ADMIN_UI_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ADMIN_UI_URL=http://localhost:3000
ADMIN_UI_PORT=3000
INTERACTION_LOG_DIR=/app/reports/interactions
REGISTER_BASE_MODEL_ON_STARTUP=1

# --- Auth service ---
AUTH_SERVICE_PORT=8090
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=changeme-admin

# --- Chat UI ---
CHAT_UI_PORT=3010
